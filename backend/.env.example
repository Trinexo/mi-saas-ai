PORT=3000
NODE_ENV=development

DATABASE_URL=postgres://postgres:postgres@localhost:5432/plataforma_test

# Genera para prod con: openssl rand -hex 64
JWT_SECRET=dev_secret_change_in_production
JWT_EXPIRES_IN=7d

# ── URLs ──────────────────────────────────────────────────────────────────────
# En producción: dominio real del frontend separado por comas si hay varios
FRONTEND_URL=http://localhost:5173,http://localhost:4173

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
# Sin configurar → usa Ethereal en local (emails fake, URL en consola)
#
# Opción recomendada para producción: Resend (resend.com, 3 000 emails/mes gratis)
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=resend
#   SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# SMTP propio (ej. Trinexo):
#   SMTP_HOST=mail.trinexo.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=usuario@trinexo.com
#   SMTP_PASS=password
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=
# SMTP_PASS=
EMAIL_FROM="Plataforma Test <noreply@tudominio.es>"
APP_NAME=Plataforma Test

# ── Stripe ────────────────────────────────────────────────────────────────────
# Test: sk_test_... / Producción: sk_live_...
# STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX