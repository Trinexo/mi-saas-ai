    "test:all": "node --test tests/services/critical-services.test.js tests/services/validate-middleware.test.js tests/services/admin-reportes-query.test.js tests/services/admin-id-params.test.js tests/services/admin-preguntas-query.test.js tests/services/catalog-query.test.js tests/smoke/e2e-smoke.test.js",
