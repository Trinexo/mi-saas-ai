# Copia estas variables a un entorno local seguro; no guardes valores reales en Git.
LOCAL_DB_URL=postgres://localhost:5432/base_local
RAILWAY_DB_URL=postgres://host-remoto:5432/base_remota

# Solo para migrate-content.mjs y migrate-users.mjs
ALLOW_REMOTE_MIGRATION=false

# Solo para clean-users.mjs
ALLOW_CLEAN_USERS=false

# Solo para reset-passwords.mjs
ALLOW_PASSWORD_RESET=false
RESET_PASSWORD=cambia-esta-password-localmente

# Solo para check-passwords.mjs; debe ser un hash bcrypt generado fuera de Git.
CHECK_PASSWORD_HASH=$2b$10$hash-bcrypt-de-ejemplo
